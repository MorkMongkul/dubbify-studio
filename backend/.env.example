
HF_TOKEN= hf_xxx                    # Hugging Face API token for accessing inference API
TRANSLATION_BACKEND=deep            # Translation Options, e.g. "deep=google-translate" or "gemini=LLMs(google model)"
PYANNOTEAI_TOKEN= sk_xxx            # PyannoteAI API token for speaker diarization and ASR
GEMINI_API_KEY= xxx                 # Google Gemini API key for LLM-based translation
CHUNK_THRESHOLD_MINUTES = xx       # audio longer than this gets chunked
CHUNK_DURATION_MINUTES  = x         # each chunk is this long
CHUNK_OVERLAP_SECONDS   = xx        # overlap between chunks

DATABASE_URL=postgresql+asyncpg://username:password@host:port/database?ssl=require  # Database connection URL
GEMINI_MODEL=gemini-3.1-flash-lite  # Google Gemini model
VOXCPM2_API_URL=https://xxxxxx.gradio.live
VOXCPM2_BACKEND